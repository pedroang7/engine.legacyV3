{% comment %}
  sections/main-cart.liquid — Engine Legacy™
  Full /cart PAGE (the drawer is separate). Native Shopify cart
  form with line-item editing and checkout. On-brand styling.
{% endcomment %}

<section class="cart-page">
  <div class="cart-page-inner">
    <h1 class="h-section" style="margin-bottom:48px">Your Selection</h1>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
        <div class="cart-lines">
          {% for item in cart.items %}
            <div class="cart-line">
              <div class="cart-line-img">
                {% if item.image %}{{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title }}{% endif %}
              </div>
              <div class="cart-line-info">
                <a href="{{ item.url }}" class="cart-line-title">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}<p class="cart-line-variant">{{ item.variant.title }}</p>{% endunless %}
                <p class="cart-line-price-mobile">{{ item.final_line_price | money }}</p>
              </div>
              <div class="cart-line-qty">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.title }}">
              </div>
              <div class="cart-line-price">{{ item.final_line_price | money }}</div>
              <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" class="cart-line-remove" aria-label="Remove {{ item.title }}">Remove</a>
            </div>
          {% endfor %}
        </div>

        <div class="cart-footer">
          <div class="cart-subtotal-row">
            <span class="cart-subtotal-label">Subtotal</span>
            <span class="cart-subtotal">{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-note">{{ settings.cart_drawer_note | default: 'Shipping, taxes, and discounts calculated at checkout.' }}</p>
          <div class="cart-actions">
            <button type="submit" name="update" class="btn-ghost">Update</button>
            <button type="submit" name="checkout" class="btn-primary cart-checkout">Proceed to Checkout →</button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <p class="body-text" style="margin-bottom:28px">Your selection is currently empty.</p>
        <a href="/collections/all" class="btn-primary">Explore the Collection →</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .cart-page{ padding:calc(var(--section-py) + 60px) var(--px) var(--section-py); border-top:1px solid var(--border) }
  .cart-page-inner{ max-width:920px; margin:0 auto }
  .cart-line{ display:grid; grid-template-columns:96px 1fr auto auto auto; gap:24px; align-items:center; padding:28px 0; border-bottom:1px solid var(--border) }
  .cart-line-img{ width:96px; height:96px; background:var(--graphite-2); overflow:hidden }
  .cart-line-title{ font-family:var(--f-b); font-size:15px; font-weight:500; color:var(--white) }
  .cart-line-variant{ font-size:12.5px; color:var(--titanium); margin-top:4px }
  .cart-line-price-mobile{ display:none }
  .cart-line-qty input{ width:64px; padding:11px; background:none; border:1px solid var(--border-md); color:var(--white); text-align:center; font-family:var(--f-b); font-size:13px }
  .cart-line-price{ font-family:var(--f-d); font-size:18px; letter-spacing:.05em; color:var(--white); white-space:nowrap }
  .cart-line-remove{ font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--titanium); text-decoration:underline; text-underline-offset:3px; transition:color .2s }
  .cart-line-remove:hover{ color:var(--crimson) }
  .cart-footer{ margin-top:48px }
  .cart-subtotal-row{ display:flex; justify-content:space-between; align-items:baseline; padding-bottom:8px; border-bottom:1px solid var(--border) }
  .cart-subtotal-label{ font-size:12px; letter-spacing:.2em; text-transform:uppercase; color:var(--titanium); font-family:var(--f-b) }
  .cart-subtotal{ font-family:var(--f-d); font-size:32px; letter-spacing:.05em; color:var(--white) }
  .cart-note{ font-size:12.5px; color:var(--titanium); margin:16px 0 28px }
  .cart-actions{ display:flex; gap:14px; justify-content:flex-end; flex-wrap:wrap }
  @media(max-width:640px){
    .cart-line{ grid-template-columns:72px 1fr auto; gap:16px; row-gap:14px }
    .cart-line-img{ width:72px; height:72px }
    .cart-line-price{ display:none }
    .cart-line-price-mobile{ display:block; font-family:var(--f-d); font-size:16px; color:var(--white); margin-top:8px }
    .cart-line-remove{ grid-column:2 / 4; justify-self:start }
    .cart-actions{ justify-content:stretch }
    .cart-actions .btn-primary,.cart-actions .btn-ghost{ flex:1; justify-content:center }
  }
</style>

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
