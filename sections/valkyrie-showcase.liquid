{%- liquid
  assign product = section.settings.product
  if product != blank
    assign product_title = product.title
    assign product_url = product.url
    assign name_first = product.title | split: ' ' | first
    assign name_rest = product.title | remove_first: name_first | strip
  else
    assign product_title = 'Valkyrie V12'
    assign product_url = '#'
    assign name_first = 'VALKYRIE'
    assign name_rest = 'V12'
  endif
-%}

<section id="s-valkyrie" class="valkyrie-wrap" aria-label="{{ product_title }}">
  <div class="valkyrie-inner">

    <div class="val-photo sr">
      {%- if product != blank and product.featured_image != blank -%}
        <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product_title }}" class="val-product-img">
      {%- else -%}
        <div class="photo-slot" style="background:linear-gradient(145deg,#100d10 0%,#1a1520 50%,#100d10 100%)"></div>
      {%- endif -%}
    </div>

    <div class="val-info">
      <div class="val-badge sr">{{ section.settings.sub_label }}</div>

      <h2 class="val-name sr d1">
        {{ name_first }}
        {%- if name_rest != blank %}<span class="val-sub-name">{{ name_rest }}</span>{% endif -%}
      </h2>

      <p class="body-text val-body sr d2">
        {{ section.settings.description | newline_to_br }}
      </p>

      {%- if product != blank -%}
        <div class="val-price sr d3">{{ product.price | money_without_trailing_zeros }}</div>
      {%- endif -%}

      <div class="sr d4">
        <a href="{{ product_url }}" class="btn-primary">
          Acquire {{ product_title }} <span class="btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
.valkyrie-wrap {
  background: var(--graphite-2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: var(--section-py) var(--px);
}
.valkyrie-inner {
  max-width: var(--mw); margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: clamp(56px, 8vw, 120px); align-items: center;
}
.val-photo { aspect-ratio: 1; position: relative; overflow: hidden; }
.val-product-img { width: 100%; height: 100%; object-fit: cover; }
.val-badge {
  display: inline-block;
  font-size: 9.5px; letter-spacing: .42em;
  color: var(--crimson); text-transform: uppercase; font-weight: 500;
  border: 1px solid rgba(177,18,38,.28);
  padding: 7px 18px; margin-bottom: 28px;
}
.val-name {
  font-family: var(--f-d);
  font-size: clamp(52px, 8vw, 112px);
  letter-spacing: .03em; line-height: .86;
  color: var(--crimson); margin-bottom: 32px;
  text-transform: uppercase;
}
.val-sub-name { display: block; color: var(--crimson); font-size: .52em; letter-spacing: .2em; }
.val-body { max-width: 44ch; margin-bottom: 44px; }
.val-price { font-family: var(--f-d); font-size: 38px; letter-spacing: .06em; color: var(--white); margin-bottom: 40px; }

@media (max-width: 1060px) {
  .valkyrie-inner { grid-template-columns: 1fr; }
  .val-photo { aspect-ratio: 4/3; order: -1; }
}
@media (max-width: 600px) {
  .val-name { font-size: clamp(48px, 14vw, 80px); }
}
</style>

{% schema %}
{
  "name": "Valkyrie Showcase",
  "settings": [
    { "type": "product", "id": "product", "label": "Product (Valkyrie V12)", "info": "Price and image are pulled automatically." },
    { "type": "text", "id": "sub_label", "label": "Badge label", "default": "Motorsport Inspired" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Not every machine is built for comfort. The Valkyrie V12 is built for those who push limits as a habit — inspired by the twelve-cylinder architectures that define motorsport excellence. Unapologetically mechanical. Engineered to perform."
    }
  ],
  "presets": [
    { "name": "Valkyrie Showcase", "category": "Engine Legacy" }
  ]
}
{% endschema %}
